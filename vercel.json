{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/reports/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, stale-while-revalidate=60" }
      ]
    }
  ]
}
